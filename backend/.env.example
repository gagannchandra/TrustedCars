NODE_ENV=development
PORT=4000
PUBLIC_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# PostgreSQL. Leave blank to use the in-memory demo store.
DATABASE_URL=postgresql://trustedcars:trustedcars@localhost:5432/trustedcars

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=30d
COOKIE_SECURE=false
DEMO_OTP=123456

# Integration placeholders. Swap for production credentials.
CLOUDINARY_CLOUD_NAME=trustedcars-demo
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RAZORPAY_KEY_ID=rzp_test_trustedcars
RAZORPAY_KEY_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=