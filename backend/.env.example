# TrustedCars Backend - Environment Configuration Template
# Copy this file to .env and fill in the values
# NEVER commit .env file to version control

# ============================================
# CRITICAL SECURITY - ROTATE ALL SECRETS
# ============================================
# Generate secrets with: openssl rand -hex 32

# Application
PROJECT_NAME=TrustedCars
ENVIRONMENT=development  # development, staging, production
API_V1_STR=/api/v1

# Security - JWT (ROTATE IN PRODUCTION)
SECRET_KEY=your-secret-key-minimum-32-chars-CHANGE-THIS
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-chars-CHANGE-THIS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security - MFA (ROTATE IN PRODUCTION)
MFA_ENCRYPTION_KEY=your-mfa-encryption-key-32-bytes-CHANGE-THIS

# Database
DATABASE_URL=postgresql+asyncpg://trustedcars_user:CHANGE_PASSWORD@localhost:5432/trustedcars_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6380/0

# Email (Resend API)
RESEND_API_KEY=your-resend-api-key-here
FROM_EMAIL=noreply@trustedcars.com

# Storage (S3/MinIO)
# Local development: use MinIO
S3_BUCKET_NAME=trustedcars-images
AWS_ACCESS_KEY_ID=minioadmin  # CHANGE IN PRODUCTION
AWS_SECRET_ACCESS_KEY=minioadmin  # CHANGE IN PRODUCTION
S3_ENDPOINT_URL=http://localhost:9000  # MinIO local endpoint
# Production: use AWS S3 (remove S3_ENDPOINT_URL)
# AWS_REGION=us-east-1

# CORS (adjust for your frontend domain)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Monitoring
SENTRY_DSN=  # Optional: Your Sentry DSN for error tracking
METRICS_PASSWORD=your-metrics-password-CHANGE-THIS

# ============================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================
# [ ] Rotate ALL secret keys (SECRET_KEY, JWT_SECRET_KEY, MFA_ENCRYPTION_KEY)
# [ ] Change database password
# [ ] Change Redis password if not using internal network
# [ ] Configure S3 with IAM credentials (not access keys)
# [ ] Change MinIO credentials if using MinIO
# [ ] Set ENVIRONMENT=production
# [ ] Configure proper CORS_ORIGINS (your production domain)
# [ ] Set up Sentry DSN for error tracking
# [ ] Use secrets manager (AWS Secrets Manager, Vault, Doppler)
# [ ] Never expose database/Redis ports to public internet
# [ ] Enable SSL/TLS for database connections
# [ ] Rotate METRICS_PASSWORD

# ============================================
# SECRETS MANAGEMENT RECOMMENDATIONS
# ============================================
# Option 1: AWS Secrets Manager
#   - Set SECRETS_MANAGER=aws
#   - Store secrets in AWS Secrets Manager
#   - Use IAM roles, not access keys
#
# Option 2: HashiCorp Vault
#   - Set SECRETS_MANAGER=vault
#   - Configure VAULT_ADDR and VAULT_TOKEN
#   - Use AppRole for authentication
#
# Option 3: Doppler
#   - Set SECRETS_MANAGER=doppler
#   - Install Doppler CLI
#   - Use doppler run command
#
# Option 4: Environment Variables (development only)
#   - Set SECRETS_MANAGER=env (default)
#   - NOT recommended for production

# ============================================
# MINIO CREDENTIAL ROTATION (if using MinIO)
# ============================================
# 1. Create new access key via MinIO Console (http://localhost:9001)
#    - Login with current credentials
#    - Identity → Service Accounts → Create Service Account
#    - Save Access Key and Secret Key
#
# 2. Update environment variables:
#    - AWS_ACCESS_KEY_ID=new-access-key
#    - AWS_SECRET_ACCESS_KEY=new-secret-key
#
# 3. Restart application:
#    - docker-compose down
#    - docker-compose up -d
#
# 4. Verify upload/delete operations work
#
# 5. Delete old access key in MinIO Console
#
# Rotation frequency: Every 90 days minimum
