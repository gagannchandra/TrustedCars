# ============================================
# TRUSTEDCARS BACKEND ENVIRONMENT CONFIGURATION
# ============================================
#
# This file documents all environment variables needed for the TrustedCars backend.
# Copy this file to .env and update the values for your environment.
#
# SETUP MODES:
# 
# 1. NATIVE DEVELOPMENT (RECOMMENDED):
#    - PostgreSQL, Redis, and MinIO run directly on localhost
#    - Connection strings use localhost:PORT format
#    - Faster performance, easier debugging, no Docker overhead
#    - See "Native Service Setup" section below
#
# 2. DOCKER COMPOSE (OPTIONAL FOR PRODUCTION):
#    - All services run in Docker containers
#    - Connection strings use Docker service names (db, redis, minio)
#    - Useful for production-like testing or containerized deployments
#
# NATIVE SERVICE SETUP INSTRUCTIONS:
#
# PostgreSQL 15:
#   macOS:    brew install postgresql@15 && brew services start postgresql@15
#   Linux:    sudo apt install postgresql-15 && sudo systemctl start postgresql
#   Windows:  Download from https://www.postgresql.org/download/windows/
#   Create DB: createdb -O trustedcars_user trustedcars_db
#   Migrations: cd backend && alembic upgrade head
#
# Redis 7:
#   macOS:    brew install redis && brew services start redis
#   Linux:    sudo apt install redis-server && sudo systemctl start redis
#   Windows:  Use WSL or download from https://github.com/microsoftarchive/redis
#   Configure: Set password in redis.conf (requirepass redis_password)
#
# MinIO (S3-compatible storage):
#   macOS:    brew install minio/stable/minio && minio server ~/minio/data
#   Linux:    wget https://dl.min.io/server/minio/release/linux-amd64/minio
#   Windows:  Download from https://min.io/download#/windows
#   Console:  http://localhost:9001 (login: minioadmin/minioadmin)
#   Create bucket: trustedcars-images with public download policy
#
# ============================================

# ============================================
# APPLICATION CONFIGURATION
# ============================================
ENVIRONMENT=development
APP_NAME=TrustedCars
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Native development with PostgreSQL running on localhost (RECOMMENDED)
DATABASE_URL=postgresql+asyncpg://trustedcars_user:trustedcars_password@localhost:5432/trustedcars_db

# Docker Compose (optional for production deployment):
# DATABASE_URL=postgresql+asyncpg://trustedcars_user:trustedcars_password@db:5432/trustedcars_db

# Connection pool settings (optimized for native development)
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE_SECONDS=1800

# PostgreSQL credentials (used for service setup and Docker)
POSTGRES_USER=trustedcars_user
POSTGRES_PASSWORD=trustedcars_password
POSTGRES_DB=trustedcars_db

# ============================================
# REDIS CONFIGURATION
# ============================================
# Native development with Redis running on localhost (RECOMMENDED)
REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_PASSWORD=redis_password

# Docker Compose (optional for production deployment):
# REDIS_URL=redis://:redis_password@redis:6379/0

# ============================================
# SECURITY KEYS (GENERATED - DO NOT COMMIT)
# ============================================
# IMPORTANT: Generate new keys for production with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
MFA_ENCRYPTION_KEY=your_mfa_encryption_key_here

# ============================================
# STORAGE CONFIGURATION (MinIO / AWS S3)
# ============================================
S3_BUCKET_NAME=trustedcars-images

# Native development with MinIO running on localhost (RECOMMENDED)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000

# Docker Compose (optional for production deployment):
# S3_ENDPOINT_URL=http://minio:9000

# Production (AWS S3) - Use real AWS credentials and remove/empty S3_ENDPOINT_URL:
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_ENDPOINT_URL=  # Leave empty or remove for AWS S3

# MinIO service credentials (for Docker or native installation)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ============================================
# EMAIL SERVICE (Resend)
# ============================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_placeholder_update_with_real_key
RESEND_FROM_EMAIL=noreply@trustedcars.com

# For testing, you can use Resend's test mode
# RESEND_API_KEY=re_test_123456789

# ============================================
# OTP / EMAIL VERIFICATION SETTINGS
# ============================================
# OTP expiry time in minutes (default: 10)
OTP_EXPIRY_MINUTES=10

# Cooldown between OTP resend requests in seconds (default: 60)
OTP_RESEND_COOLDOWN_SECONDS=60

# Maximum OTP verification attempts before requiring new OTP (default: 5)
OTP_MAX_ATTEMPTS=5

# Rate limiting window for OTP requests in minutes (default: 15)
OTP_RATE_LIMIT_WINDOW_MINUTES=15

# Maximum OTP requests within rate limit window (default: 10)
OTP_RATE_LIMIT_MAX_REQUESTS=10

# DEVELOPMENT ONLY: Disable OTP authentication for easier testing
# Set to true to bypass OTP verification (users can login with email/password directly)
# WARNING: Never enable this in production!
DISABLE_OTP_AUTH=false

# ============================================
# CORS CONFIGURATION
# ============================================
# Cross-Origin Resource Sharing (CORS) configuration for frontend-backend communication
#
# WHAT IS CORS?
# CORS controls which web origins (protocol + domain + port) can make requests to the API.
# It's required when frontend and backend run on different ports/domains.
#
# WHEN IS CORS NEEDED?
# - Development Mode: Frontend dev server (localhost:5173) calling backend API (localhost:8000)
# - Production: If frontend is hosted separately from backend (e.g., CDN, Netlify, Vercel)
# - NOT needed: When backend serves frontend (integrated mode, same origin)
#
# SECURITY REQUIREMENT:
# The CORS middleware is configured with allow_credentials=True to support cookie-based
# JWT authentication. This requires EXPLICIT origins (wildcards "*" are not allowed).
#
# Development Configuration:
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:5174"]
# These ports cover:
# - http://localhost:5173: Vite dev server default port
# - http://localhost:3000: Alternative dev server (React Create App, Next.js)
# - http://localhost:5174: Alternative Vite port when 5173 is occupied
#
# Production Configuration (UPDATE WITH YOUR ACTUAL DOMAIN):
# CORS_ORIGINS=["https://trustedcars.com","https://www.trustedcars.com"]
#
# IMPORTANT PRODUCTION NOTES:
# ✓ Always use HTTPS (https://) in production, never HTTP
# ✓ Never use wildcard origins ("*") with credentials enabled
# ✓ List ALL subdomain variants (www and non-www) if needed
# ✓ Include staging environments if applicable: ["https://trustedcars.com","https://staging.trustedcars.com"]
# ✓ Do NOT include http:// localhost origins in production (security risk)
#
# Example Multi-Environment Production Configuration:
# CORS_ORIGINS=["https://trustedcars.com","https://www.trustedcars.com","https://app.trustedcars.com"]
#
# Troubleshooting CORS Errors:
# - "Access-Control-Allow-Origin" error → Add your frontend origin to CORS_ORIGINS
# - "credentials mode is 'include'" error → Verify explicit origins (no wildcards)
# - Preflight OPTIONS errors → Check allow_methods and allow_headers in main.py

# ============================================
# FRONTEND SERVING CONFIGURATION
# ============================================
# Enable backend to serve built frontend static files from /frontend/dist
# Set to true for integrated mode (single endpoint for frontend + API)
# Set to false for API-only mode (separate frontend dev server)
SERVE_FRONTEND=true

# USAGE:
# - Development Mode (separate servers): Set SERVE_FRONTEND=false
#   Frontend: npm run dev (http://localhost:5173 with hot reload)
#   Backend: uvicorn app.main:app --reload (http://localhost:8000 for API only)
#
# - Integrated Mode (production-like): Set SERVE_FRONTEND=true
#   1. Build frontend: cd frontend && npm run build
#   2. Start backend: uvicorn app.main:app --reload
#   3. Access everything at: http://localhost:8000 (frontend + API)
#
# NOTE: Before enabling SERVE_FRONTEND=true, ensure frontend is built:
#       cd frontend && npm run build

# ============================================
# MONITORING & OBSERVABILITY (Optional)
# ============================================
# Sentry error tracking (leave empty to disable)
SENTRY_DSN=

# Prometheus metrics endpoint password
METRICS_PASSWORD=metrics_password_change_in_prod

# ============================================
# DOCKER CONFIGURATION (Production)
# ============================================
DOCKER_REGISTRY=trustedcars
IMAGE_TAG=latest
