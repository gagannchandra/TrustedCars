# ============================================
# APPLICATION CONFIGURATION
# ============================================
ENVIRONMENT=development
APP_NAME=TrustedCars
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Docker Compose connection string (service name: db)
DATABASE_URL=postgresql+asyncpg://trustedcars_user:trustedcars_password@db:5432/trustedcars_db

# For local development outside Docker, use:
# DATABASE_URL=postgresql+asyncpg://trustedcars_user:trustedcars_password@localhost:5432/trustedcars_db

# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# PostgreSQL Docker Service credentials
POSTGRES_USER=trustedcars_user
POSTGRES_PASSWORD=trustedcars_password
POSTGRES_DB=trustedcars_db

# ============================================
# REDIS CONFIGURATION
# ============================================
# Docker Compose connection string (service name: redis)
REDIS_URL=redis://:redis_password@redis:6379/0

# For local development outside Docker, use:
# REDIS_URL=redis://:redis_password@localhost:6379/0

REDIS_PASSWORD=redis_password

# ============================================
# SECURITY KEYS (GENERATED - DO NOT COMMIT)
# ============================================
# IMPORTANT: Generate new keys for production with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
MFA_ENCRYPTION_KEY=your_mfa_encryption_key_here

# ============================================
# STORAGE CONFIGURATION (MinIO / AWS S3)
# ============================================
S3_BUCKET_NAME=trustedcars-images

# Development (MinIO) - Docker Compose service name: minio
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://minio:9000

# For local development outside Docker, use:
# S3_ENDPOINT_URL=http://localhost:9000

# Production (AWS S3) - Comment out S3_ENDPOINT_URL and use real AWS credentials:
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_ENDPOINT_URL=  # Leave empty or remove for AWS S3

# MinIO Docker Service credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ============================================
# EMAIL SERVICE (Resend)
# ============================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_placeholder_update_with_real_key
RESEND_FROM_EMAIL=noreply@trustedcars.com

# For testing, you can use Resend's test mode
# RESEND_API_KEY=re_test_123456789

# ============================================
# OTP / EMAIL VERIFICATION SETTINGS
# ============================================
# OTP expiry time in minutes (default: 10)
OTP_EXPIRY_MINUTES=10

# Cooldown between OTP resend requests in seconds (default: 60)
OTP_RESEND_COOLDOWN_SECONDS=60

# Maximum OTP verification attempts before requiring new OTP (default: 5)
OTP_MAX_ATTEMPTS=5

# Rate limiting window for OTP requests in minutes (default: 15)
OTP_RATE_LIMIT_WINDOW_MINUTES=15

# Maximum OTP requests within rate limit window (default: 10)
OTP_RATE_LIMIT_MAX_REQUESTS=10

# DEVELOPMENT ONLY: Disable OTP authentication for easier testing
# Set to true to bypass OTP verification (users can login with email/password directly)
# WARNING: Never enable this in production!
DISABLE_OTP_AUTH=false

# ============================================
# CORS CONFIGURATION
# ============================================
# Development: Allow local frontend origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:5174"]

# Production: Update with your actual domain
# CORS_ORIGINS=["https://trustedcars.com","https://www.trustedcars.com"]

# ============================================
# MONITORING & OBSERVABILITY (Optional)
# ============================================
# Sentry error tracking (leave empty to disable)
SENTRY_DSN=

# Prometheus metrics endpoint password
METRICS_PASSWORD=metrics_password_change_in_prod

# ============================================
# DOCKER CONFIGURATION (Production)
# ============================================
DOCKER_REGISTRY=trustedcars
IMAGE_TAG=latest
