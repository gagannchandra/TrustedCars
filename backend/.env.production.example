# TrustedCars Backend - Production Environment Template
# CRITICAL: Use a secrets manager in production (AWS Secrets Manager, Vault, Doppler)
# This file is for documentation purposes only

# ============================================
# APPLICATION
# ============================================
PROJECT_NAME=TrustedCars
ENVIRONMENT=production
API_V1_STR=/api/v1

# ============================================
# SECURITY - ALL SECRETS MUST BE ROTATED
# ============================================
# NEVER use default/example values in production
# Generate with: openssl rand -hex 32

SECRET_KEY=<use-secrets-manager>
JWT_SECRET_KEY=<use-secrets-manager>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

MFA_ENCRYPTION_KEY=<use-secrets-manager>

# ============================================
# DATABASE
# ============================================
# Use managed database (AWS RDS, Digital Ocean Managed Database, etc.)
# Enable SSL/TLS connection
# Use connection pooling (PgBouncer)

DATABASE_URL=postgresql+asyncpg://user:password@rds-endpoint:5432/trustedcars_db?ssl=require
DATABASE_POOL_SIZE=50
DATABASE_MAX_OVERFLOW=100

# ============================================
# REDIS
# ============================================
# Use managed Redis (AWS ElastiCache, Redis Cloud, etc.)
# Enable TLS connection
# Use password authentication

REDIS_URL=rediss://:password@redis-endpoint:6380/0?ssl_cert_reqs=required

# ============================================
# EMAIL
# ============================================
RESEND_API_KEY=<use-secrets-manager>
FROM_EMAIL=noreply@yourdomain.com

# ============================================
# STORAGE - AWS S3
# ============================================
# RECOMMENDED: Use IAM roles instead of access keys
# If using access keys, rotate every 90 days

S3_BUCKET_NAME=trustedcars-production-images
AWS_REGION=us-east-1

# Option 1: IAM Role (RECOMMENDED)
# - Attach IAM role to EC2/ECS/Lambda
# - No access keys needed
# - Leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY empty

# Option 2: Access Keys (if IAM role not available)
# AWS_ACCESS_KEY_ID=<use-secrets-manager>
# AWS_SECRET_ACCESS_KEY=<use-secrets-manager>

# DO NOT set S3_ENDPOINT_URL in production (uses AWS S3)

# ============================================
# CORS
# ============================================
# Only allow your production frontend domain
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# MONITORING
# ============================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
METRICS_PASSWORD=<use-secrets-manager>

# ============================================
# SECRETS MANAGER CONFIGURATION
# ============================================

# Option 1: AWS Secrets Manager (RECOMMENDED for AWS deployments)
SECRETS_MANAGER=aws
AWS_SECRETS_MANAGER_REGION=us-east-1
# Secrets are fetched from AWS Secrets Manager by name:
# - trustedcars/jwt-secret
# - trustedcars/mfa-encryption-key
# - trustedcars/database-url
# - trustedcars/redis-url
# - trustedcars/resend-api-key

# Option 2: HashiCorp Vault
# SECRETS_MANAGER=vault
# VAULT_ADDR=https://vault.yourdomain.com:8200
# VAULT_TOKEN=<service-token>
# VAULT_NAMESPACE=trustedcars

# Option 3: Doppler
# SECRETS_MANAGER=doppler
# DOPPLER_TOKEN=<service-token>
# Use: doppler run -- uvicorn app.main:app

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
# [ ] All secrets stored in secrets manager, not environment variables
# [ ] Database uses SSL/TLS connection
# [ ] Redis uses TLS connection and password
# [ ] S3 uses IAM role (no access keys)
# [ ] CORS_ORIGINS only includes production domains
# [ ] Sentry configured for error tracking
# [ ] Database/Redis not exposed to public internet
# [ ] Application runs behind load balancer with SSL termination
# [ ] Health checks configured (/health/live, /health/ready)
# [ ] Monitoring and alerting configured (CloudWatch, Datadog, etc.)
# [ ] Backup strategy configured for database
# [ ] Log aggregation configured (CloudWatch Logs, ELK, Datadog)
# [ ] Rate limiting tested and configured
# [ ] Security headers verified (HSTS, CSP, X-Frame-Options)
# [ ] DDoS protection enabled (CloudFlare, AWS Shield)
# [ ] WAF rules configured (AWS WAF, CloudFlare)

# ============================================
# INFRASTRUCTURE SECURITY
# ============================================
# Network:
# - Database in private subnet only
# - Redis in private subnet only
# - Application in private subnet, accessed via load balancer
# - S3 bucket not publicly accessible (presigned URLs only)
# - Security groups restrict inbound traffic
#
# Access Control:
# - Use IAM roles, not access keys
# - Principle of least privilege
# - Enable MFA for admin access
# - Rotate credentials every 90 days
#
# Monitoring:
# - Enable CloudTrail for audit logging
# - Enable VPC Flow Logs
# - Enable S3 access logging
# - Set up CloudWatch alarms for anomalies

# ============================================
# CREDENTIAL ROTATION SCHEDULE
# ============================================
# Every 30 days:
#   - METRICS_PASSWORD
#
# Every 90 days:
#   - JWT_SECRET_KEY (requires user re-login)
#   - AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (if used)
#   - Database password
#   - Redis password
#
# Every 180 days:
#   - SECRET_KEY
#   - MFA_ENCRYPTION_KEY (requires MFA re-enrollment)
#
# On suspected compromise:
#   - Rotate ALL secrets immediately
#   - Revoke all user sessions
#   - Review audit logs
#   - Investigate breach
