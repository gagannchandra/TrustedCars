# .env.production.example
# This file illustrates a production environment setup

# Database & Redis (Point to production instances instead of local docker)
DATABASE_URL=postgresql+asyncpg://prod_user:prod_pass@prod-db-host:5432/trustedcars_db
REDIS_URL=redis://prod-redis-host:6379/0

# Core Secrets
SECRET_KEY=your-secure-secret-key
JWT_SECRET_KEY=your-secure-jwt-key
MFA_ENCRYPTION_KEY=your-secure-mfa-key
METRICS_PASSWORD=your-metrics-password

# CORS Settings
# Update this with the actual domain(s) of your production frontend
CORS_ORIGINS=["https://www.trustedcars.com", "https://admin.trustedcars.com"]

# Object Storage (S3 / MinIO / etc.)
S3_BUCKET_NAME=trustedcars-production-images
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# Remove S3_ENDPOINT_URL for standard AWS S3, or set it if using DigitalOcean Spaces/MinIO
# S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com

# Integrations
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0
SECRET_PROVIDER=aws  # Use aws to fetch secrets from AWS Secrets Manager
