# TrustedCars Frontend - Production Environment Configuration
# Copy this file to .env.production for production builds

# API Base URL - MUST point to your production backend API
VITE_API_URL=https://api.trustedcars.com/api/v1

# Sentry DSN for error tracking (recommended for production)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEMO_MODE=false
