#!/bin/bash
# Pre-commit hook for secret scanning
# Prevents committing .env files and detects secret patterns

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "🔍 Running pre-commit secret scanning..."

# Block .env file commits
ENV_FILES=$(git diff --cached --name-only | grep -E '\.env$|\.env\..*$' || true)
if [ -n "$ENV_FILES" ]; then
    echo -e "${RED}❌ BLOCKED: Attempting to commit .env files!${NC}"
    echo "The following .env files are staged:"
    echo "$ENV_FILES" | sed 's/^/  - /'
    echo ""
    echo "These files may contain sensitive credentials and should not be committed to Git."
    echo "Please unstage them with: git reset HEAD <file>"
    exit 1
fi

# Secret pattern detection
echo "Scanning for secret patterns..."

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}✓ No files to scan${NC}"
    exit 0
fi

# Patterns to detect (basic secret patterns)
FOUND_SECRETS=0

# Check each staged file
while IFS= read -r file; do
    if [ -f "$file" ]; then
        # Skip binary files
        if file "$file" | grep -q "text"; then
            # Check for common secret patterns (assignment with long values)
            # Exclude documentation and example patterns
            if grep -nHE '(SECRET_KEY|API_KEY|PASSWORD|TOKEN|PRIVATE_KEY|AWS_ACCESS_KEY|REDIS_TOKEN|JWT_SECRET|ENCRYPTION_KEY)\s*=\s*["\x27]?[A-Za-z0-9+/=_-]{20,}["\x27]?' "$file" | grep -vE '(your_|example|placeholder|<|>|xxx|test_secret|dummy|sample|\$\{)' 2>/dev/null; then
                echo -e "${RED}❌ Potential secret found in: $file${NC}"
                grep -nHE '(SECRET_KEY|API_KEY|PASSWORD|TOKEN|PRIVATE_KEY|AWS_ACCESS_KEY|REDIS_TOKEN|JWT_SECRET|ENCRYPTION_KEY)\s*=\s*["\x27]?[A-Za-z0-9+/=_-]{20,}["\x27]?' "$file" | grep -vE '(your_|example|placeholder|<|>|xxx|test_secret|dummy|sample|\$\{)' | head -5
                FOUND_SECRETS=1
            fi
            
            # Check for hardcoded credentials patterns
            if grep -nHE '(password|token|secret|key)[\s]*[:=][\s]*["\x27][^\x27"]{8,}["\x27]' "$file" | grep -v -E '(test|example|dummy|placeholder|your_|<|>|\$\{)' 2>/dev/null; then
                echo -e "${YELLOW}⚠️  Possible hardcoded credential in: $file${NC}"
                # Don't block on warnings, just alert
            fi
        fi
    fi
done <<< "$STAGED_FILES"

if [ $FOUND_SECRETS -eq 1 ]; then
    echo ""
    echo -e "${RED}❌ BLOCKED: Potential secrets detected in staged files!${NC}"
    echo ""
    echo "Please remove hardcoded secrets and use environment variables instead."
    echo "For development, use backend/.env (already in .gitignore)"
    echo "For production, use a secret manager (AWS Secrets Manager, Doppler, Vault)"
    echo ""
    echo "To bypass this check (not recommended): git commit --no-verify"
    exit 1
fi

echo -e "${GREEN}✓ No secrets detected${NC}"
echo -e "${GREEN}✓ Pre-commit checks passed${NC}"
exit 0
